# ──────────────────────────────────────────────────────────────────────────────
# Secure Login Service — Environment Variables
# Copy this file to .env and fill in the values before running the service.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
SERVER_PORT=8080

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
DB_URL=jdbc:postgresql://localhost:5432/securelogin
DB_USERNAME=securelogin
DB_PASSWORD=change_me

# ── JWT ───────────────────────────────────────────────────────────────────────
# Must be at least 32 characters for HS256
JWT_SECRET=change-me-to-a-long-random-secret-value
# Token lifetime in milliseconds (default: 1 hour)
JWT_EXPIRATION_MS=3600000

# ── SMTP / Email ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=your-smtp-username
SMTP_PASSWORD=your-smtp-password
EMAIL_FROM=noreply@yourdomain.com

# ── Application ───────────────────────────────────────────────────────────────
# Base URL used to build email verification links
APP_BASE_URL=http://localhost:8080
